<article class="container">
  <header class="rs-header">
    <h1>Daniel Friedman</h1>
    <div>New York, NY</div>
    <a :href="$data.mailUrl" @text="$data.mailUrl"></a>
    <a :href="getUrl('home')" @text="siteUrl"></a>
  </header>

  <div class="rs-section" webc:for="section of sections">
    <h2 class="rs-section-heading" @text="section.title"></h2>
    <div class="rs-section-content">
      <section class="rs-item" webc:for="item of section.items">
        <header class="rs-item-header">
          <div>
            <h3 class="rs-item-name">
              <a
                :href="item.url"
                target="_blank"
                @text="item.name"
                webc:if="item.url"
              ></a>
              <span webc:else webc:nokeep @text="item.name"></span>
            </h3>
            <span class="text-sm" @text="item.period"></span>
          </div>
          <div>
            <div>
              <span
                class="rs-item-sub1"
                webc:if="item.sub1"
                @text="item.sub1"
              ></span>
              <span
                webc:if="item.sub2"
                class="rs-item-sub2 text-secondary"
                @text="item.sub2"
              ></span>
            </div>
            <span class="text-secondary" @text="item.location"></span>
          </div>
        </header>
        <div class="rs-item-details">
          <ul
            class="rs-item-content text-sm"
            webc:if="Array.isArray(item.content)"
          >
            <li
              webc:for="bullet of item.content"
              class="rs-item-bullet"
              @html="bullet"
            ></li>
          </ul>
          <p class="rs-item-content text-sm" webc:else @html="item.content"></p>
          <div webc:if="item.tech" class="rs-item-tech text-xs">
            <span webc:for="tech of item.tech" @html="tech"></span>
          </div>
        </div>
      </section>
    </div>
  </div>
</article>

<style>
  .container {
