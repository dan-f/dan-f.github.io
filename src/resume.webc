    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rs-item {
    flex: 5;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .rs-item-header {
    > * {
      display: flex;
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .rs-item-name {
    display: inline-block;
  }

  .rs-item-details {
    display: flex;
    flex-direction: row;
  }

  .rs-item-content {
    flex: 4;
    &:is(p) {
      margin: unset;
    }
  }

